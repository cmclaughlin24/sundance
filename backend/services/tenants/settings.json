{
  "port": 80,
  "host": "http://localhost:8081",
  "persistence": {
    "driver": "mongodb",
    "options": {
      "uri": "mongodb://mongo:27017",
      "database_name": "tenants"
    }
  },
  "cache": {
    "type": "redis",
    "options": {
      "host": "redis",
      "port": 6379
    }
  },
  "log_level": "debug",
  "worker": {
    "interval": 1,
    "pool_size": 10,
    "retry_limit": 5
  }
}
