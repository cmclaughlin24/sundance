{
  "port": 80,
  "logLevel": "debug",
  "server": {
    "host": "http://localhost:8080"
  },
  "database": {
    "driver": "mongodb",
    "mongodb": {
      "uri": "mongodb://mongo:27017",
      "databaseName": "forms"
    }
  },
  "cache": {
    "type": "redis",
    "redis": {
      "host": "redis",
      "port": 6379
    }
  },
  "worker": {
    "interval": 1,
    "poolSize": 10,
    "retryLimit": 5
  }
}
